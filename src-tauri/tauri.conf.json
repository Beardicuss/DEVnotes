{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevNotes Desktop",
  "version": "1.0.0",
  "identifier": "studio.softcurse.devnotes-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label":       "main",
        "title":       "DevNotes Desktop",
        "width":       1920,
        "height":      1080,
        "minWidth":    1280,
        "minHeight":   720,
        "resizable":   true,
        "decorations": false,
        "transparent": false,
        "shadow":      true,
        "center":      true,
        "visible":     true
      }
    ],
    "trayIcon": {
      "iconPath":        "icons/tray.png",
      "iconAsTemplate":  false,
      "menuOnLeftClick": false,
      "tooltip":         "DevNotes Desktop"
    }
  },
  "bundle": {
    "active":  true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm":       "sha256",
      "timestampUrl":          ""
    }
  },
  "plugins": {
    "fs":        { "all": true, "scope": { "allow": ["$APPDATA/DevNotes/**"], "deny": [] } },
    "shell":     { "open": true },
    "autostart": {}
  }
}
