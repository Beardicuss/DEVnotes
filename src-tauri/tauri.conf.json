{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevNotes Desktop",
  "version": "1.0.0",
  "identifier": "studio.softcurse.devnotes-desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DevNotes Desktop",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "decorations": false,
        "center": true,
        "visible": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "nsis": {
      "displayLanguageSelector": false,
      "installMode": "currentUser",
      "shortcut": true,
      "compression": "lzma"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "fs": {
      "all": true,
      "scope": {
        "allow": [
          "$APPDATA/DevNotes/**"
        ],
        "deny": []
      }
    },
    "shell": {
      "open": true
    }
  }
}